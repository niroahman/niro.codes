---
interface Props {
  lines?: string[];
  lineDelay?: number;
}

const defaultLines = [
  'NIRO.EXE v1.0.0',
  '──────────────────────────────────',
  'loading personality ......... [OK]',
  'mounting homelab ............ [OK]',
  'calibrating opinions ........ [OK]',
  'connecting to the void ...... [OK]',
  '──────────────────────────────────',
  'system ready.',
];

const { lines = defaultLines, lineDelay = 110 } = Astro.props;
---

<div
  id="boot-sequence"
  aria-live="polite"
  data-line-count={lines.length}
  data-line-delay={lineDelay}
>
  {
    lines.map((line, i) => (
      <p class="boot-line" style={`animation-delay: ${i * lineDelay}ms`}>
        {line}
      </p>
    ))
  }
</div>

<script>
  const el = document.getElementById('boot-sequence') as HTMLElement;
  const lineCount = parseInt(el.dataset.lineCount!);
  const lineDelay = parseInt(el.dataset.lineDelay!);

  function dispatch() {
    (window as Window & { __bootComplete?: boolean }).__bootComplete = true;
    document.dispatchEvent(new CustomEvent('bootcomplete'));
  }

  const navEntry = performance.getEntriesByType('navigation')[0] as PerformanceNavigationTiming;
  const isBackForward = navEntry?.type === 'back_forward';

  if (isBackForward) {
    el.style.display = 'none';
    setTimeout(dispatch, 0);
  } else {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const totalMs = reduced ? 0 : lineCount * lineDelay + 250;
    setTimeout(dispatch, totalMs);
  }
</script>

<style>
  #boot-sequence {
    font-size: 1rem;
    line-height: 1.8;
  }

  .boot-line {
    margin: 0;
    opacity: 0;
    animation: appear 220ms ease-out forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .boot-line {
      animation: none;
      opacity: 1;
    }
  }
</style>
