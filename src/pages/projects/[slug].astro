---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SlideEmbed from '../../components/SlideEmbed';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, tech, github, demo, slideUrl } = project.data;
---

<BaseLayout title={title} description={description}>
  <a slot="back" href="/projects">&larr; projects/</a>
  <main class="project-detail">
    <div class="detail-body">
      <div class="detail-meta">
        <h1 class="detail-title glow">{title}</h1>
        <p class="detail-desc">{description}</p>

        <ul class="tech-list">
          {
            tech.map((t) => (
              <li class="tech-tag">
                <a href={`/tags/${t.toLowerCase()}`}>{t}</a>
              </li>
            ))
          }
        </ul>

        <div class="detail-links">
          {
            demo && (
              <a href={demo} target="_blank" rel="noopener noreferrer" class="detail-link">
                demo ↗
              </a>
            )
          }
          {
            github && (
              <a href={github} target="_blank" rel="noopener noreferrer" class="detail-link">
                github ↗
              </a>
            )
          }
        </div>
      </div>

      <div class="detail-content prose">
        <Content />
      </div>

      {slideUrl && <SlideEmbed url={slideUrl} title={`${title} slides`} client:visible />}
    </div>
  </main>
</BaseLayout>

<style>
  .project-detail {
    max-width: 760px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    font-size: 0.875rem;
  }

  .page-header {
    margin-bottom: 2rem;
    font-size: 0.75rem;
  }

  .back {
    color: var(--phosphor-dim);
    text-decoration: none;
    transition: color 0.15s;
  }

  .back:hover {
    color: var(--phosphor);
  }

  .detail-meta {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--dim);
  }

  .detail-title {
    font-size: 1.5rem;
    margin: 0 0 0.5rem;
  }

  .detail-desc {
    color: var(--phosphor-dim);
    margin: 0 0 1rem;
    line-height: 1.6;
  }

  .tech-list {
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tech-tag {
    font-size: 0.7rem;
    border: 1px solid var(--dim);
    padding: 0.1rem 0.5rem;
    color: var(--phosphor-dim);
  }

  .tech-tag a {
    color: inherit;
    text-decoration: none;
  }

  .tech-tag a:hover {
    color: var(--phosphor);
  }

  .detail-links {
    display: flex;
    gap: 1.25rem;
  }

  .detail-link {
    color: var(--phosphor-dim);
    text-decoration: none;
    font-size: 0.8rem;
    transition: color 0.15s;
  }

  .detail-link:hover {
    color: var(--phosphor);
  }

  /* MDX prose */
  .prose {
    color: var(--phosphor);
    line-height: 1.75;
    opacity: 0.9;
  }

  .prose :global(h2) {
    font-size: 1rem;
    margin: 2rem 0 0.75rem;
    color: var(--phosphor);
    opacity: 1;
  }

  .prose :global(p) {
    margin: 0 0 1rem;
  }

  .prose :global(a) {
    color: var(--phosphor);
    opacity: 0.7;
    transition: opacity 0.15s;
  }

  .prose :global(a:hover) {
    opacity: 1;
  }

  .prose :global(code) {
    font-size: 0.85em;
    color: var(--amber);
  }

  /* SlideEmbed */
  :global(.slide-embed) {
    margin-top: 2rem;
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
  }

  :global(.slide-embed iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 1px solid var(--dim);
  }
</style>
