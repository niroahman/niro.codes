<style>
  .now {
    max-width: 640px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    font-size: 0.875rem;
  }

  .now-logo {
    font-size: 9px;
    line-height: 1.2;
    white-space: pre;
    color: var(--phosphor);
    text-shadow:
      0 0 8px var(--phosphor),
      0 0 20px color-mix(in srgb, var(--phosphor) 40%, transparent);
    margin: 0 0 1.5rem;
  }

  .updated {
    font-size: 0.7rem;
    color: var(--phosphor-dim);
    margin: 0 0 2.5rem;
  }

  .now-body {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .section-title {
    font-size: 0.875rem;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--phosphor);
    margin: 0 0 0.75rem;
  }

  .section-title span {
    color: var(--phosphor-dim);
    font-weight: normal;
  }

  .now-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: var(--phosphor);
    opacity: 0.85;
    line-height: 1.6;
  }

  .now-list li::before {
    content: '‚Äď ';
    color: var(--phosphor-dim);
  }
</style>
