---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((p) => ({ params: { slug: p.id }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, date, tags } = post.data;

function formatDate(d: Date) {
  const [y, m, day] = d.toISOString().slice(0, 10).split('-');
  return `${parseInt(day)}.${parseInt(m)}.${y}`;
}
---

<BaseLayout title={title} description={description}>
  <a slot="back" href="/blog">&larr; blog/</a>
  <main class="post-detail">
    <article>
      <div class="post-meta">
        <h1 class="post-title glow">{title}</h1>
        <time class="post-date" datetime={date.toISOString()}>{formatDate(date)}</time>
        {
          tags && tags.length > 0 && (
            <div class="tag-wrapper">
              <ul class="tag-list" id={`tags-${post.id}`}>
                {tags.map((t, i) => (
                  <li class="tag" data-index={i}>
                    <a href={`/tags/${t.toLowerCase()}`}>{t}</a>
                  </li>
                ))}
              </ul>
              {tags.length > 4 && (
                <>
                  <button
                    class="tag-toggle"
                    aria-expanded="false"
                    onClick={`
                      const btn = document.getElementById('tag-toggle-${post.id}');
                      const list = document.getElementById('tags-${post.id}');
                      if (!btn || !list) return;
                      const expanded = btn.getAttribute('aria-expanded') === 'true';
                      btn.setAttribute('aria-expanded', !expanded);
                      list.classList.toggle('expanded', !expanded);
                      btn.textContent = expanded ? '+${tags.length - 4} more' : 'show less';
                    `}
                    id={`tag-toggle-${post.id}`}
                  >
                    +{tags.length - 4} more
                  </button>
                </>
              )}
            </div>
          )
        }
      </div>

      <div class="prose">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  .post-detail {
    max-width: 680px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    font-size: 0.875rem;
  }

  .page-header {
    margin-bottom: 2rem;
    font-size: 0.75rem;
  }

  .back {
    color: var(--phosphor-dim);
    text-decoration: none;
    transition: color 0.15s;
  }

  .back:hover {
    color: var(--phosphor);
  }

  .post-meta {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--dim);
  }

  .post-title {
    font-size: 1.4rem;
    margin: 0 0 0.5rem;
  }

  .post-date {
    font-size: 0.75rem;
    color: var(--phosphor-dim);
  }

  .tag-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.7rem;
    border: 1px solid var(--dim);
    padding: 0.1rem 0.4rem;
    color: var(--phosphor-dim);
  }

  .tag a {
    color: inherit;
    text-decoration: none;
  }

  .tag a:hover {
    color: var(--phosphor);
  }

  /* ── Mobile tag collapse ── */
  .tag-wrapper {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    margin: 0.75rem 0 0;
  }

  .tag-wrapper > .tag-list {
    margin: 0;
  }

  @media (max-width: 600px) {
    .tag-list .tag:nth-child(n + 5) {
      display: none;
    }

    .tag-list.expanded .tag:nth-child(n + 5) {
      display: inline-flex;
    }
  }

  .tag-toggle {
    display: none;
  }

  @media (max-width: 600px) {
    .tag-toggle {
      display: inline-flex;
      background: none;
      border: 1px solid var(--dim);
      color: var(--phosphor-dim);
      font-family: inherit;
      font-size: 0.65rem;
      padding: 0.1rem 0.4rem;
      cursor: pointer;
      transition: color 0.15s;
    }

    .tag-toggle:hover {
      color: var(--phosphor);
      border-color: var(--phosphor);
    }
  }

  .prose {
    color: var(--phosphor);
    line-height: 1.8;
    opacity: 0.88;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .prose :global(h2) {
    font-size: 1rem;
    margin: 2rem 0 0.75rem;
    color: var(--phosphor);
    opacity: 1;
  }

  .prose :global(p) {
    margin: 0 0 1.1rem;
  }

  .prose :global(a) {
    color: var(--phosphor);
    opacity: 0.7;
    transition: opacity 0.15s;
  }

  .prose :global(a:hover) {
    opacity: 1;
  }

  .prose :global(code) {
    font-size: 0.85em;
    color: var(--amber);
  }

  .prose :global(pre) {
    border: 1px solid var(--dim);
    padding: 1rem;
    overflow-x: auto;
    margin: 1rem 0;
    font-size: 0.8rem;
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--dim);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--phosphor-dim);
    font-style: italic;
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 1.5rem 0;
    border-radius: 4px;
  }

  .prose :global(img) + :global(em) {
    display: block;
    text-align: center;
    font-size: 0.75rem;
    color: var(--phosphor-dim);
    margin-top: -0.75rem;
    margin-bottom: 1rem;
  }
</style>
