---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { buildTagList } from '../../utils/tags';

const all = await getCollection('blog', ({ data }) => data.published);
const posts = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const tags = buildTagList(posts.map((p) => ({ tags: p.data.tags ?? [] })));

function formatDate(d: Date) {
  const [y, m, day] = d.toISOString().slice(0, 10).split('-');
  return `${parseInt(day)}.${parseInt(m)}.${y}`;
}
---

<BaseLayout title="blog" description="Thoughts and writeups by Niro Åhman">
  <a slot="back" href="/">&larr; ~/index</a>
  <main class="blog">
    <div class="blog-layout">
      <ul class="post-list">
        {
          posts.map((p) => (
            <li
              class="post-item"
              data-search={`${p.data.title} ${p.data.description} ${(p.data.tags ?? []).join(' ')}`.toLowerCase()}
              data-tags={(p.data.tags ?? []).map((t) => t.toLowerCase()).join(' ')}
            >
              <time class="post-date" datetime={p.data.date.toISOString()}>
                {formatDate(p.data.date)}
              </time>
              <div class="post-body">
                <h2 class="post-title">
                  <a href={`/blog/${p.id}`}>{p.data.title}</a>
                </h2>
                <p class="post-desc">{p.data.description}</p>
                {p.data.tags && (
                  <div class="tag-wrapper">
                    <ul class="tag-list" id={`tags-${p.id}`}>
                      {p.data.tags.map((t) => (
                        <li class="tag">
                          <a href={`/tags/${t.toLowerCase()}`}>{t}</a>
                        </li>
                      ))}
                    </ul>
                    {p.data.tags.length > 4 && (
                      <button
                        class="tag-toggle"
                        aria-expanded="false"
                        id={`tog-${p.id}`}
                        onclick={`document.getElementById('tags-${p.id}').classList.toggle('expanded');this.textContent=this.textContent==='show less'?'+${p.data.tags.length - 4} more':'show less';this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true')`}
                      >
                        +{p.data.tags.length - 4} more
                      </button>
                    )}
                  </div>
                )}
              </div>
            </li>
          ))
        }
      </ul>
      <p class="no-results" aria-live="polite"></p>

      <Sidebar
        tags={tags}
        inputId="blog-search"
        itemSelector=".post-item"
        tagLabel="tags"
        collapsible
      />
    </div>
  </main>
</BaseLayout>

<style>
  .blog {
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    font-size: 0.875rem;
  }

  .blog-layout {
    display: grid;
    grid-template-columns: 1fr 210px;
    gap: 3rem;
    align-items: start;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .post-item {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 1.25rem;
    padding: 1.25rem 0;
    border-top: 1px solid var(--dim);
  }

  .no-results {
    display: none;
    padding: 1.25rem 0;
    border-top: 1px solid var(--dim);
    color: var(--phosphor-dim);
    margin: 0;
  }

  .post-date {
    color: var(--phosphor-dim);
    font-size: 0.75rem;
    padding-top: 0.2rem;
  }

  .post-title a {
    color: var(--phosphor);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: bold;
  }

  .post-title a:hover {
    text-decoration: underline;
  }

  .post-desc {
    color: var(--phosphor-dim);
    margin: 0.35rem 0 0;
    line-height: 1.6;
  }

  .tag-list {
    list-style: none;
    margin: 0.5rem 0 0;
    padding: 0;
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.7rem;
    border: 1px solid var(--dim);
    padding: 0.1rem 0.4rem;
    color: var(--phosphor-dim);
  }

  .tag a {
    color: inherit;
    text-decoration: none;
  }

  .tag a:hover {
    color: var(--phosphor);
  }

  /* ── Mobile tag collapse ── */
  .tag-wrapper {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    margin: 0.5rem 0 0;
  }

  .tag-wrapper > .tag-list {
    margin: 0;
  }

  @media (max-width: 700px) {
    .tag-list .tag:nth-child(n + 5) {
      display: none;
    }

    .tag-list.expanded .tag:nth-child(n + 5) {
      display: inline-flex;
    }
  }

  .tag-toggle {
    display: none;
  }

  @media (max-width: 700px) {
    .tag-toggle {
      display: inline-flex;
      background: none;
      border: 1px solid var(--dim);
      color: var(--phosphor-dim);
      font-family: inherit;
      font-size: 0.65rem;
      padding: 0.1rem 0.4rem;
      cursor: pointer;
      transition: color 0.15s;
    }

    .tag-toggle:hover {
      color: var(--phosphor);
      border-color: var(--phosphor);
    }
  }

  @media (max-width: 700px) {
    .blog-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    :global(.sidebar) {
      position: static;
      order: -1;
      border-bottom: 1px solid var(--dim);
      padding-bottom: 1.5rem;
    }

    .post-item {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
