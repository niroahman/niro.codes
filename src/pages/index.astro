</CRTLayout>

<script>
  function handleBootComplete() {
    const boot = document.getElementById('boot-sequence');
    const menu = document.getElementById('home-menu');

    if (boot?.classList.contains('skip')) {
      // Return visit: lines invisible but space preserved, show menu now
      menu?.classList.add('visible');
      return;
    }

    // First visit: fade lines out top-to-bottom, keep space
    const lines = boot?.querySelectorAll<HTMLElement>('.boot-line') ?? [];
    lines.forEach((line, i) => {
      line.style.transitionDelay = `${i * 45}ms`;
      line.style.transition = 'opacity 180ms ease-out';
      line.style.opacity = '0';
    });

    setTimeout(
      () => {
        menu?.classList.add('visible');
      },
      lines.length * 45 + 220
    );
  }

  if ((window as Window & { __bootComplete?: boolean }).__bootComplete) {
    handleBootComplete();
  } else {
    document.addEventListener('bootcomplete', handleBootComplete, { once: true });
  }
</script>

<style>
  .terminal {
    display: flex;
    flex-direction: column;
    height: 100dvh;
    max-width: 640px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    box-sizing: border-box;
  }

  .terminal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    font-size: 0.75rem;
  }

  .terminal-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  #home-menu {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    opacity: 0;
    transition: opacity 400ms ease-out;
  }

  #home-menu.visible {
    opacity: 1;
  }

  .menu-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .menu-item,
  .game-entry {
    display: grid;
    grid-template-columns: 3rem 10rem 1fr;
    gap: 0.5rem;
    align-items: baseline;
    color: var(--phosphor);
    text-decoration: none;
    font-size: 1rem;
    padding: 0.2rem 0;
    transition: opacity 0.15s;
  }

  .menu-item:hover,
  .game-entry:hover {
    opacity: 0.75;
  }

  .menu-key {
    opacity: 0.5;
  }

  .menu-label {
    font-weight: bold;
  }

  .menu-desc {
    color: var(--phosphor-dim);
    font-size: 0.9rem;
  }

  .ext-links {
    display: flex;
    gap: 2rem;
    border: 1px dashed var(--dim);
    padding: 0.6rem 1rem;
    font-size: 0.875rem;
  }

  .ext-link {
    color: var(--phosphor-dim);
    text-decoration: none;
    transition: color 0.15s;
  }

  .ext-link:hover {
    color: var(--phosphor);
  }

  .game-coin {
    color: var(--amber);
    animation: blink 1.2s step-end infinite;
  }

  .logo-block {
    margin-bottom: 0.5rem;
  }

  .logo {
    font-size: 10px;
    line-height: 1.2;
    white-space: pre;
    color: var(--phosphor);
    text-shadow:
      0 0 8px var(--phosphor),
      0 0 20px color-mix(in srgb, var(--phosphor) 40%, transparent);
    margin: 0 0 0.75rem;
  }

  .subtitle {
    font-size: 0.75rem;
    color: var(--phosphor-dim);
    border-bottom: 1px solid var(--dim);
    padding-bottom: 0.5rem;
  }
</style>
