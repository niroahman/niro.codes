</script>

<style>
  .terminal {
    display: flex;
    flex-direction: column;
    height: 100%;
    max-width: 640px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    box-sizing: border-box;
  }

  .terminal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    font-size: 1rem;
  }

  .header-label {
    font-size: 0.875rem;
    color: var(--phosphor);
    opacity: 0.7;
  }

  :global([data-theme='light']) .header-label {
    color: color-mix(in oklch, var(--phosphor) 80%, black);
  }

  .terminal-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .content-center {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2rem;
    padding-top: 4rem;
  }

  #home-menu {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    opacity: 0;
    transition: opacity 400ms ease-out;
  }

  #home-menu.visible {
    opacity: 1;
  }

  .menu-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .menu-item,
  .game-entry {
    display: grid;
    grid-template-columns: 3rem 10rem 1fr;
    gap: 0.5rem;
    align-items: baseline;
    color: var(--phosphor);
    text-decoration: none;
    font-size: 1rem;
    padding: 0.2rem 0;
    transition: opacity 0.15s;
  }

  .menu-item:hover,
  .game-entry:hover {
    opacity: 0.75;
  }

  .menu-item[data-selected],
  .game-entry[data-selected] {
    opacity: 1;
    background: color-mix(in srgb, var(--phosphor) 10%, transparent);
    border-radius: 2px;
  }

  .menu-key {
    opacity: 0.5;
  }

  .menu-label {
    font-weight: bold;
  }

  .menu-desc {
    color: var(--phosphor-dim);
    font-size: 0.9rem;
  }

  .ext-links {
    display: flex;
    gap: 2rem;
    border: 1px dashed var(--dim);
    padding: 0.6rem 1rem;
    font-size: 0.875rem;
  }

  .ext-link {
    display: inline-flex;
    align-items: center;
    color: var(--phosphor-dim);
    text-decoration: none;
    transition: color 0.15s;
  }

  .ext-link:hover {
    color: var(--phosphor);
  }

  .ext-link[data-selected] {
    color: var(--phosphor);
    background: color-mix(in srgb, var(--phosphor) 10%, transparent);
    border-radius: 2px;
  }

  .game-coin {
    color: var(--amber);
    animation: blink 1.2s step-end infinite;
  }

  .logo-block {
    margin-bottom: 0.5rem;
  }

  .logo {
    font-size: 8px;
    line-height: 1.2;
    white-space: pre;
    color: var(--phosphor);
    text-shadow:
      0 0 8px var(--phosphor),
      0 0 20px color-mix(in srgb, var(--phosphor) 40%, transparent);
    margin: 0 0 1.5rem;
    animation: flicker 9s infinite;
  }

  @media (max-width: 600px) {
    .logo {
      font-size: 5.5px;
    }

    .menu-item,
    .game-entry {
      grid-template-columns: 2.5rem 7rem 1fr;
    }

    .subtitle {
      white-space: normal;
      overflow: visible;
      text-overflow: clip;
    }

    .terminal-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.4rem;
    }

    .terminal-header :global(.appearance-controls) {
      align-self: flex-end;
    }

    .theme-arrow {
      font-size: 0;
    }

    .theme-arrow::before {
      content: '‚Üď';
      font-size: 0.875rem;
    }
  }

  .subtitle {
    font-size: 0.8rem;
    color: var(--phosphor-dim);
    border-bottom: 1px solid var(--dim);
    padding-bottom: 0.5rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .subtitle-location {
    white-space: nowrap;
  }
</style>
